<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unique Template — Premium Digital Design Templates</title>
<style>
  @font-face{
    font-family:'Lora'; src:local('Lora');
  }
  :root{
    --plum:#2C1B4A;
    --plum-deep:#1D1130;
    --gold:#C9A24C;
    --gold-light:#E4C878;
    --ivory:#FAF6F0;
    --paper:#FFFFFF;
    --coral:#E4664A;
    --coral-deep:#C94E34;
    --muted:#6B5C82;
    --line: rgba(44,27,74,0.14);
  }
  *{ box-sizing:border-box; margin:0; padding:0; }
  body{
    font-family:'Poppins', 'Segoe UI', sans-serif;
    background:var(--ivory);
    color:var(--plum-deep);
    -webkit-font-smoothing:antialiased;
    padding-bottom:30px;
  }
  h1,h2,h3,.serif{ font-family:'Lora', serif; }

  /* ---------- HEADER ---------- */
  header{
    position:sticky; top:0; z-index:40;
    background:var(--plum);
    padding:14px 16px;
  }
  .header-row{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
  .logo{ display:flex; align-items:center; gap:9px; }
  .logo-mark{ width:30px; height:30px; flex-shrink:0; }
  .logo-text{ color:var(--ivory); font-size:17px; letter-spacing:1.2px; font-weight:700; font-family:'Lora'; }
  .logo-text span{ color:var(--gold-light); }
  .admin-link{
    font-size:11px; color:rgba(250,246,240,0.65); background:none; border:1px solid rgba(250,246,240,0.3);
    padding:6px 12px; border-radius:20px; cursor:pointer; letter-spacing:0.4px;
  }
  .tagline-bar{
    text-align:center; font-size:11px; color:var(--gold-light); letter-spacing:1.5px;
    margin-top:8px; text-transform:uppercase; font-weight:500;
  }

  /* ---------- HERO ---------- */
  .hero{
    padding:40px 20px 30px; text-align:center; position:relative; overflow:hidden;
    background:linear-gradient(180deg, var(--plum) 0%, var(--plum) 55%, var(--ivory) 55%);
  }
  .hero-inner{
    background:var(--paper); border-radius:16px; padding:34px 22px;
    box-shadow:0 20px 50px rgba(44,27,74,0.18);
    max-width:480px; margin:0 auto; position:relative;
  }
  .hero-eyebrow{
    font-size:11px; letter-spacing:2.5px; color:var(--coral); text-transform:uppercase; font-weight:600;
  }
  .hero h1{
    font-size:26px; line-height:1.25; margin:10px 0 10px; color:var(--plum-deep); font-weight:600;
  }
  .hero h1 em{ font-style:italic; color:var(--gold); }
  .hero p{ font-size:13px; color:var(--muted); line-height:1.6; }
  .hero-stats{
    display:flex; justify-content:center; gap:24px; margin-top:18px; padding-top:16px;
    border-top:1px solid var(--line);
  }
  .hstat{ text-align:center; }
  .hstat b{ display:block; font-family:'Lora'; font-size:18px; color:var(--plum); }
  .hstat span{ font-size:10px; color:var(--muted); letter-spacing:0.4px; }

  /* ---------- CATALOG ---------- */
  .section-title{
    padding:26px 16px 12px; display:flex; align-items:baseline; justify-content:space-between;
  }
  .section-title h2{ font-size:18px; font-weight:600; color:var(--plum-deep); }
  .section-title span{ font-size:11px; color:var(--muted); }

  .filter-row{
    display:flex; gap:8px; padding:0 16px 14px; overflow-x:auto;
  }
  .filter-chip{
    flex-shrink:0; padding:6px 14px; border-radius:16px; border:1px solid var(--line);
    background:var(--paper); font-size:11.5px; color:var(--muted); cursor:pointer; white-space:nowrap;
  }
  .filter-chip.active{ background:var(--plum); color:var(--ivory); border-color:var(--plum); }

  .grid{ display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:0 14px; }
  .card{
    background:var(--paper); border-radius:12px; overflow:hidden; border:1px solid var(--line);
    display:flex; flex-direction:column;
  }
  .card-img{
    aspect-ratio:1/1; background:#F1ECE4; position:relative; overflow:hidden;
    display:flex; align-items:center; justify-content:center;
  }
  .card-img img{ width:100%; height:100%; object-fit:cover; }
  .card-id{
    position:absolute; top:8px; left:8px; background:rgba(44,27,74,0.85); color:var(--gold-light);
    font-size:9.5px; padding:3px 7px; border-radius:3px; letter-spacing:0.5px; font-weight:600;
  }
  .card-body{ padding:10px 11px 12px; display:flex; flex-direction:column; gap:5px; }
  .card-body h3{ font-size:12.5px; font-weight:500; line-height:1.3; min-height:32px; font-family:'Poppins'; color:var(--plum-deep); }
  .rating-row{ display:flex; align-items:center; gap:5px; }
  .stars{ color:var(--gold); font-size:12px; letter-spacing:1px; }
  .rating-num{ font-size:10.5px; color:var(--muted); }
  .sold-txt{ font-size:10px; color:var(--muted); }
  .price-row{ display:flex; align-items:baseline; justify-content:space-between; margin-top:2px;}
  .price{ font-family:'Lora'; font-weight:700; color:var(--coral); font-size:16px; }
  .buy-btn{
    margin-top:6px; width:100%; padding:9px; border:none; border-radius:7px;
    background:var(--plum); color:var(--ivory); font-weight:600; font-size:12px; cursor:pointer;
    letter-spacing:0.3px;
  }
  .buy-btn:active{ background:var(--plum-deep); }
  .empty-state{
    grid-column:1/-1; text-align:center; padding:50px 20px; color:var(--muted); font-size:13px;
  }

  /* ---------- HOW IT WORKS ---------- */
  .how{ padding:30px 16px; }
  .how-steps{ display:flex; flex-direction:column; gap:14px; margin-top:14px; }
  .how-step{ display:flex; gap:12px; align-items:flex-start; background:var(--paper); padding:14px; border-radius:10px; border:1px solid var(--line);}
  .how-num{
    width:26px; height:26px; border-radius:50%; background:var(--gold); color:var(--plum-deep);
    display:flex; align-items:center; justify-content:center; font-weight:700; font-size:12px; flex-shrink:0;
  }
  .how-step h4{ font-size:13px; margin-bottom:3px; }
  .how-step p{ font-size:11.5px; color:var(--muted); line-height:1.5; }

  footer{ text-align:center; padding:30px 16px 10px; font-size:11px; color:var(--muted); line-height:1.7; }

  /* ---------- BUY MODAL ---------- */
  .modal-overlay{
    position:fixed; inset:0; background:rgba(29,17,48,0.6); z-index:70;
    display:flex; align-items:flex-end; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity 0.25s ease;
  }
  .modal-overlay.show{ opacity:1; pointer-events:all; }
  .modal{
    background:var(--ivory); width:100%; max-width:460px; max-height:92vh; overflow-y:auto;
    border-radius:16px 16px 0 0; transform:translateY(40px); transition:transform 0.28s cubic-bezier(.4,0,.2,1);
  }
  .modal-overlay.show .modal{ transform:translateY(0); }
  .modal-head{
    padding:16px; display:flex; align-items:center; justify-content:space-between; background:var(--plum);
    position:sticky; top:0; z-index:2;
  }
  .modal-head h3{ color:var(--ivory); font-size:15px; }
  .close-x{ background:none; border:none; color:var(--ivory); font-size:22px; cursor:pointer; line-height:1; }
  .modal-body{ padding:18px 16px; display:flex; flex-direction:column; gap:16px; }

  .buy-summary{ display:flex; gap:12px; align-items:center; background:var(--paper); padding:10px; border-radius:10px; border:1px solid var(--line);}
  .buy-summary img{ width:60px; height:60px; object-fit:cover; border-radius:6px; }
  .buy-summary h4{ font-size:12.5px; margin-bottom:3px; }
  .buy-summary .price{ font-size:15px; }

  .gcash-box{
    background:var(--paper); border:1.5px dashed var(--gold); border-radius:10px; padding:16px; text-align:center;
  }
  .gcash-box .gtitle{ font-size:11px; letter-spacing:1.5px; color:var(--muted); text-transform:uppercase; margin-bottom:8px; font-weight:600; }
  #qrCanvas{ margin:8px auto 10px; display:block; border-radius:8px; }
  .gcash-number{
    font-family:'Lora'; font-size:21px; font-weight:700; color:var(--plum); letter-spacing:1px; margin:4px 0;
  }
  .gcash-name{ font-size:11.5px; color:var(--muted); margin-bottom:10px; }
  .copy-btn{
    background:var(--gold); color:var(--plum-deep); border:none; padding:7px 18px; border-radius:16px;
    font-size:11.5px; font-weight:600; cursor:pointer;
  }

  .field label{
    display:block; font-size:10.5px; font-weight:600; color:var(--plum); text-transform:uppercase;
    letter-spacing:0.4px; margin-bottom:5px;
  }
  .field input{
    width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:7px; font-size:13px;
    background:#fff; outline:none; font-family:'Poppins';
  }
  .field input:focus{ border-color:var(--gold); }
  .file-field{
    border:1.5px dashed var(--line); border-radius:8px; padding:14px; text-align:center; font-size:11.5px;
    color:var(--muted); cursor:pointer; background:#fff;
  }
  .submit-order-btn{
    width:100%; padding:13px; border:none; border-radius:8px; background:var(--coral); color:#fff;
    font-weight:600; font-size:13.5px; cursor:pointer;
  }
  .order-err{ font-size:11px; color:var(--coral-deep); display:none; }
  .order-err.show{ display:block; }

  .success-box{ text-align:center; padding:20px 10px; }
  .success-box .check{
    width:56px; height:56px; border-radius:50%; background:var(--plum); color:var(--gold-light);
    display:flex; align-items:center; justify-content:center; margin:0 auto 14px; font-size:26px;
  }
  .success-box h4{ font-size:16px; margin-bottom:8px; color:var(--plum-deep); }
  .success-box p{ font-size:12.5px; color:var(--muted); line-height:1.6; margin-bottom:16px; }
  .order-ref{ font-family:'Lora'; font-size:13px; background:var(--paper); border-radius:6px; padding:8px; border:1px solid var(--line); }

  /* ---------- ADMIN PANEL ---------- */
  .admin-overlay{
    position:fixed; inset:0; background:rgba(29,17,48,0.65); z-index:80; display:flex;
    align-items:center; justify-content:center; padding:16px;
    opacity:0; pointer-events:none; transition:opacity 0.2s ease;
  }
  .admin-overlay.show{ opacity:1; pointer-events:all; }
  .admin-lock{
    background:var(--paper); border-radius:14px; padding:26px 22px; width:100%; max-width:320px; text-align:center;
  }
  .admin-lock h3{ font-size:16px; margin-bottom:6px; }
  .admin-lock p{ font-size:11.5px; color:var(--muted); margin-bottom:14px; }
  .admin-lock input{
    width:100%; padding:11px; border:1px solid var(--line); border-radius:8px; text-align:center;
    font-size:16px; letter-spacing:4px; margin-bottom:10px; font-family:'Lora';
  }
  .admin-lock button{
    width:100%; padding:11px; border:none; border-radius:8px; background:var(--plum); color:var(--ivory);
    font-weight:600; cursor:pointer; font-size:13px;
  }
  .admin-lock .hint{ font-size:10px; color:rgba(107,92,130,0.6); margin-top:10px; }

  .admin-panel{
    position:fixed; inset:0; background:var(--ivory); z-index:90; overflow-y:auto;
    display:none;
  }
  .admin-panel.show{ display:block; }
  .admin-top{
    background:var(--plum); color:var(--ivory); padding:16px; display:flex; align-items:center;
    justify-content:space-between; position:sticky; top:0; z-index:2;
  }
  .admin-top h3{ font-size:15px; }
  .admin-tabs{ display:flex; gap:8px; padding:14px 16px 0; }
  .admin-tab{
    padding:8px 16px; border-radius:8px; font-size:12px; font-weight:600; cursor:pointer;
    background:var(--paper); color:var(--muted); border:1px solid var(--line);
  }
  .admin-tab.active{ background:var(--plum); color:var(--ivory); border-color:var(--plum); }
  .admin-content{ padding:16px; }
  .admin-section{ display:none; }
  .admin-section.active{ display:block; }

  .upload-form{ background:var(--paper); border-radius:12px; padding:16px; border:1px solid var(--line); margin-bottom:16px; }
  .upload-form h4{ font-size:14px; margin-bottom:12px; }
  .form-grid{ display:flex; flex-direction:column; gap:12px; }
  .auto-id-preview{
    font-family:'Lora'; font-size:12px; background:var(--ivory); padding:8px 10px; border-radius:6px;
    color:var(--muted); border:1px dashed var(--line);
  }
  select.field-input, .field-input{
    width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:7px; font-size:13px; font-family:'Poppins';
  }
  .img-preview{ width:80px; height:80px; border-radius:8px; object-fit:cover; margin-top:8px; display:none; }
  .add-btn{
    width:100%; padding:12px; border:none; border-radius:8px; background:var(--coral); color:#fff;
    font-weight:600; font-size:13px; cursor:pointer; margin-top:4px;
  }

  .admin-item{
    display:flex; gap:10px; background:var(--paper); border-radius:10px; padding:10px; margin-bottom:8px;
    border:1px solid var(--line); align-items:center;
  }
  .admin-item img{ width:48px; height:48px; border-radius:6px; object-fit:cover; }
  .admin-item-info{ flex:1; }
  .admin-item-info h5{ font-size:12px; }
  .admin-item-info span{ font-size:10.5px; color:var(--muted); }
  .del-btn{ background:none; border:none; color:var(--coral); font-size:11px; cursor:pointer; text-decoration:underline; }

  .order-card{
    background:var(--paper); border-radius:10px; padding:12px; margin-bottom:10px; border:1px solid var(--line);
  }
  .order-card .oc-top{ display:flex; justify-content:space-between; margin-bottom:6px; }
  .order-card .oc-id{ font-family:'Lora'; font-size:12px; font-weight:700; }
  .order-status{ font-size:9.5px; padding:2px 8px; border-radius:10px; font-weight:600; letter-spacing:0.3px; text-transform:uppercase; }
  .order-status.pending{ background:#FCE9C6; color:#8A6416; }
  .order-status.approved{ background:#D6E8D6; color:#2F5C2F; }
  .order-card p{ font-size:11.5px; color:var(--muted); margin-bottom:2px; }
  .order-card .oc-actions{ display:flex; gap:8px; margin-top:10px; }
  .oc-btn{ flex:1; padding:8px; border-radius:6px; border:none; font-size:11px; font-weight:600; cursor:pointer; }
  .oc-btn.approve{ background:var(--plum); color:var(--ivory); }
  .oc-btn.link{ background:var(--ivory); color:var(--plum); border:1px solid var(--line); }
  .empty-admin{ text-align:center; padding:30px; color:var(--muted); font-size:12.5px; }
</style>
</head>
<body>

<header>
  <div class="header-row">
    <div class="logo">
      <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
        <polygon points="20,3 34,14 28,37 12,37 6,14" fill="#C9A24C"/>
        <polygon points="20,3 34,14 20,19" fill="#E4C878"/>
        <polygon points="6,14 20,19 12,37" fill="#9A7B36"/>
        <polygon points="34,14 28,37 20,19" fill="#B08D3F"/>
      </svg>
      <div class="logo-text">UNIQUE<span>TEMPLATE</span></div>
    </div>
    <button class="admin-link" id="adminBtn">Admin</button>
  </div>
  <div class="tagline-bar">Premium Canva Design Templates</div>
</header>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">Digital Templates Shop</div>
    <h1>Design that makes<br>your brand look <em>unique</em>.</h1>
    <p>Ready-to-edit Canva templates for creators and small businesses. Buy once, edit anytime, launch your content in minutes.</p>
    <div class="hero-stats">
      <div class="hstat"><b id="statCount">0</b><span>TEMPLATES</span></div>
      <div class="hstat"><b id="statSold">0</b><span>SOLD</span></div>
      <div class="hstat"><b>GCash</b><span>PAYMENT</span></div>
    </div>
  </div>
</section>

<div class="section-title">
  <h2>Browse Templates</h2>
  <span id="catalogCount">0 items</span>
</div>
<div class="filter-row" id="filterRow"></div>
<div class="grid" id="productGrid"></div>

<div class="how">
  <div class="section-title" style="padding:0 0 0;"><h2>How It Works</h2></div>
  <div class="how-steps">
    <div class="how-step">
      <div class="how-num">1</div>
      <div><h4>Pick a template</h4><p>Browse the shop and choose the design that fits your brand.</p></div>
    </div>
    <div class="how-step">
      <div class="how-num">2</div>
      <div><h4>Pay via GCash</h4><p>Send the exact amount to the GCash number shown, then enter your reference number.</p></div>
    </div>
    <div class="how-step">
      <div class="how-num">3</div>
      <div><h4>Get your link</h4><p>Once payment is verified, you'll receive the Canva template link to start editing.</p></div>
    </div>
  </div>
</div>

<footer>
  UNIQUE TEMPLATE · Digital Design Shop<br>
  Orders are manually verified via GCash reference number.<br>
  All templates are for personal & small business use.
</footer>

<!-- BUY MODAL -->
<div class="modal-overlay" id="buyOverlay">
  <div class="modal">
    <div class="modal-head">
      <h3 id="buyModalTitle">Buy Template</h3>
      <button class="close-x" id="closeBuy">&times;</button>
    </div>
    <div class="modal-body" id="buyModalBody"></div>
  </div>
</div>

<!-- ADMIN LOCK -->
<div class="admin-overlay" id="adminOverlay">
  <div class="admin-lock">
    <h3>Admin Access</h3>
    <p>Enter your passcode to manage templates & orders.</p>
    <input type="password" id="adminPass" placeholder="••••••" maxlength="12">
    <button id="adminUnlock">Unlock</button>
    <div class="hint">Default passcode: <b>unique2026</b><br>(change this in the code before you launch)</div>
    <button style="background:none;border:none;color:var(--muted);font-size:11px;margin-top:12px;cursor:pointer;text-decoration:underline;" id="adminCancel">Cancel</button>
  </div>
</div>

<!-- ADMIN PANEL -->
<div class="admin-panel" id="adminPanel">
  <div class="admin-top">
    <h3>Seller Dashboard</h3>
    <button class="close-x" id="closeAdmin">&times;</button>
  </div>
  <div class="admin-tabs">
    <div class="admin-tab active" data-tab="upload">Upload</div>
    <div class="admin-tab" data-tab="manage">My Templates</div>
    <div class="admin-tab" data-tab="orders">Orders</div>
  </div>
  <div class="admin-content">
    <div class="admin-section active" id="tab-upload">
      <div class="upload-form">
        <h4>Add New Template</h4>
        <div class="form-grid">
          <div class="field">
            <label>Auto-generated Product Code</label>
            <div class="auto-id-preview" id="autoIdPreview">UT-001</div>
          </div>
          <div class="field">
            <label>Template Title</label>
            <input type="text" class="field-input" id="newTitle" placeholder="e.g. Aesthetic Instagram Carousel Pack">
          </div>
          <div class="field">
            <label>Category</label>
            <select class="field-input" id="newCategory">
              <option>Instagram Post</option>
              <option>Instagram Story</option>
              <option>Resume/CV</option>
              <option>Invitation</option>
              <option>Presentation</option>
              <option>Planner</option>
              <option>Other</option>
            </select>
          </div>
          <div class="field">
            <label>Pricing</label>
            <select class="field-input" id="newPricingType">
              <option value="paid">Paid Template</option>
              <option value="free">Free Template</option>
            </select>
          </div>
          <div class="field" id="priceFieldWrap">
            <label>Price (₱)</label>
            <input type="number" class="field-input" id="newPrice" placeholder="e.g. 250">
          </div>
          <div class="field">
            <label>Starting Rating</label>
            <select class="field-input" id="newRating">
              <option value="5">★★★★★ (5.0)</option>
              <option value="4.5">★★★★☆ (4.5)</option>
              <option value="4">★★★★ (4.0)</option>
            </select>
          </div>
          <div class="field">
            <label>Preview Image</label>
            <label class="file-field" for="newImage">Tap to upload preview photo (JPG/PNG)</label>
            <input type="file" id="newImage" accept="image/*" style="display:none;">
            <img class="img-preview" id="imgPreview">
          </div>
          <div class="field">
            <label>Delivery Link (Canva / Google Drive share link)</label>
            <input type="text" class="field-input" id="newLink" placeholder="https://www.canva.com/design/...">
          </div>
          <button class="add-btn" id="addTemplateBtn">+ Add Template to Shop</button>
        </div>
      </div>
    </div>

    <div class="admin-section" id="tab-manage">
      <div id="manageList"></div>
    </div>

    <div class="admin-section" id="tab-orders">
      <div id="ordersList"></div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
<script>
const ADMIN_PASSCODE = "unique2026"; // Jehu: change this before launching publicly
const GCASH_NUMBER = "09365885603";
const GCASH_NAME = "Jehu Del Monte";

let templates = [];
let orders = [];

// ---------- STORAGE ----------
async function loadData(){
  try{
    const t = await window.storage.get('templates', true);
    templates = t ? JSON.parse(t.value) : [];
  } catch(e){ templates = []; }
  try{
    const o = await window.storage.get('orders', true);
    orders = o ? JSON.parse(o.value) : [];
  } catch(e){ orders = []; }
  renderAll();
}
async function saveTemplates(){
  await window.storage.set('templates', JSON.stringify(templates), true);
}
async function saveOrders(){
  await window.storage.set('orders', JSON.stringify(orders), true);
}

function peso(n){ return '₱' + Number(n).toLocaleString('en-PH'); }
function starsHtml(rating){
  const full = Math.round(rating);
  return '★'.repeat(full) + '☆'.repeat(5-full);
}

// ---------- RENDER CATALOG ----------
let activeFilter = 'All';
function renderAll(){
  renderStats();
  renderFilters();
  renderGrid();
  renderManageList();
  renderOrdersList();
}

function renderStats(){
  document.getElementById('statCount').textContent = templates.length;
  document.getElementById('statSold').textContent = templates.reduce((s,t)=>s+(t.sold||0),0);
}

function renderFilters(){
  const cats = ['All', 'Free', ...new Set(templates.map(t=>t.category))];
  document.getElementById('filterRow').innerHTML = cats.map(c=>`
    <div class="filter-chip ${c===activeFilter?'active':''}" onclick="setFilter('${c}')">${c}</div>
  `).join('');
}
function setFilter(c){ activeFilter = c; renderAll(); }

function renderGrid(){
  const grid = document.getElementById('productGrid');
  let list;
  if(activeFilter === 'All') list = templates;
  else if(activeFilter === 'Free') list = templates.filter(t=>t.price===0);
  else list = templates.filter(t=>t.category===activeFilter);
  document.getElementById('catalogCount').textContent = list.length + ' items';
  if(list.length === 0){
    grid.innerHTML = `<div class="empty-state">No templates yet. Go to Admin → Upload to add your first one!</div>`;
    return;
  }
  grid.innerHTML = list.map(t => `
    <div class="card">
      <div class="card-img">
        <span class="card-id">${t.id}</span>
        <img src="${t.image}" alt="${t.title}">
      </div>
      <div class="card-body">
        <h3>${t.title}</h3>
        <div class="rating-row">
          <span class="stars">${starsHtml(t.rating)}</span>
          <span class="rating-num">${t.rating}</span>
        </div>
        <div class="sold-txt">${t.sold||0} ${t.price===0?'downloads':'sold'} · ${t.category}</div>
        <div class="price-row"><span class="price" ${t.price===0?'style="color:#2F5C2F;"':''}>${t.price===0?'FREE':peso(t.price)}</span></div>
        <button class="buy-btn" onclick="openBuyModal('${t.id}')">${t.price===0?'Get Free Template':'Buy with GCash'}</button>
      </div>
    </div>
  `).join('');
}

// ---------- BUY FLOW ----------
function openBuyModal(id){
  const t = templates.find(x=>x.id===id);
  if(!t) return;
  const isFree = t.price === 0;
  document.getElementById('buyModalTitle').textContent = isFree ? 'Get Free Template' : 'Buy Template';

  const gcashSection = isFree ? '' : `
    <div class="gcash-box">
      <div class="gtitle">Send Payment via GCash</div>
      <canvas id="qrCanvas" width="140" height="140"></canvas>
      <div class="gcash-number">${GCASH_NUMBER}</div>
      <div class="gcash-name">${GCASH_NAME}</div>
      <button class="copy-btn" id="copyGcashBtn">Copy Number</button>
    </div>`;

  const refField = isFree ? '' : `
    <div class="field">
      <label>GCash Reference Number</label>
      <input type="text" id="gcashRef" placeholder="e.g. 1234567890123">
    </div>`;

  document.getElementById('buyModalBody').innerHTML = `
    <div class="buy-summary">
      <img src="${t.image}">
      <div>
        <h4>${t.title}</h4>
        <div class="price" ${isFree?'style="color:#2F5C2F;"':''}>${isFree?'FREE':peso(t.price)}</div>
      </div>
    </div>
    ${gcashSection}
    <div class="field">
      <label>Your Full Name</label>
      <input type="text" id="buyerName" placeholder="Juan Dela Cruz">
    </div>
    <div class="field">
      <label>Email (to receive your template link)</label>
      <input type="email" id="buyerEmail" placeholder="you@email.com">
    </div>
    ${refField}
    <div class="order-err" id="buyErr">Please fill in all fields before submitting.</div>
    <button class="submit-order-btn" id="submitOrderBtn">${isFree ? 'Get My Free Template' : "I've Sent Payment — Submit"}</button>
  `;
  document.getElementById('buyOverlay').classList.add('show');
  if(!isFree){
    try{
      new QRious({ element: document.getElementById('qrCanvas'), value: 'GCash: ' + GCASH_NUMBER + ' (' + GCASH_NAME + ')', size:140, foreground:'#2C1B4A', background:'#FFFFFF' });
    } catch(e){}
    document.getElementById('copyGcashBtn').onclick = () => {
      navigator.clipboard.writeText(GCASH_NUMBER).then(()=>{
        document.getElementById('copyGcashBtn').textContent = 'Copied!';
        setTimeout(()=>{ document.getElementById('copyGcashBtn').textContent = 'Copy Number'; }, 1500);
      });
    };
  }

  document.getElementById('submitOrderBtn').onclick = async () => {
    const name = document.getElementById('buyerName').value.trim();
    const email = document.getElementById('buyerEmail').value.trim();
    const ref = isFree ? '' : document.getElementById('gcashRef').value.trim();
    const err = document.getElementById('buyErr');
    if(!name || !email || (!isFree && !ref)){
      err.classList.add('show');
      return;
    }
    err.classList.remove('show');
    const orderId = 'ORD-' + Date.now().toString().slice(-8);
    const order = {
      orderId, templateId: t.id, templateName: t.title, price: t.price,
      buyerName: name, buyerEmail: email, gcashRef: ref,
      status: isFree ? 'approved' : 'pending', date: new Date().toLocaleString('en-PH')
    };
    orders.unshift(order);
    if(isFree){
      t.sold = (t.sold||0) + 1;
      await saveTemplates();
    }
    await saveOrders();
    showSuccess(order, isFree ? t.link : null);
  };
}

function showSuccess(order, freeLink){
  document.getElementById('buyModalTitle').textContent = freeLink ? 'Template Ready' : 'Order Submitted';
  const body = freeLink ? `
    <div class="success-box">
      <div class="check">✓</div>
      <h4>Thank you, ${order.buyerName}!</h4>
      <p>Here's your free template link — save this now, and it's also been noted for your email <b>${order.buyerEmail}</b>.</p>
      <a href="${freeLink}" target="_blank" class="order-ref" style="display:block; text-decoration:none; color:var(--plum); word-break:break-all;">${freeLink}</a>
      <div class="order-ref" style="margin-top:10px;">Order ID: ${order.orderId}</div>
    </div>
  ` : `
    <div class="success-box">
      <div class="check">✓</div>
      <h4>Thank you, ${order.buyerName}!</h4>
      <p>Your order is now pending verification. Once the seller confirms your GCash payment, your template link will be sent to <b>${order.buyerEmail}</b>.</p>
      <div class="order-ref">Order ID: ${order.orderId}</div>
    </div>
  `;
  document.getElementById('buyModalBody').innerHTML = body;
}

document.getElementById('closeBuy').onclick = () => {
  document.getElementById('buyOverlay').classList.remove('show');
};

// ---------- ADMIN LOCK ----------
document.getElementById('adminBtn').onclick = () => {
  document.getElementById('adminOverlay').classList.add('show');
  document.getElementById('adminPass').value = '';
  document.getElementById('adminPass').focus();
};
document.getElementById('adminCancel').onclick = () => {
  document.getElementById('adminOverlay').classList.remove('show');
};
document.getElementById('adminUnlock').onclick = () => {
  if(document.getElementById('adminPass').value === ADMIN_PASSCODE){
    document.getElementById('adminOverlay').classList.remove('show');
    document.getElementById('adminPanel').classList.add('show');
    updateAutoId();
  } else {
    document.getElementById('adminPass').style.borderColor = '#E4664A';
    document.getElementById('adminPass').value = '';
  }
};
document.getElementById('closeAdmin').onclick = () => {
  document.getElementById('adminPanel').classList.remove('show');
};

// ---------- ADMIN TABS ----------
document.querySelectorAll('.admin-tab').forEach(tab=>{
  tab.onclick = () => {
    document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
  };
});

// ---------- UPLOAD FORM ----------
function updateAutoId(){
  const next = templates.length + 1;
  document.getElementById('autoIdPreview').textContent = 'UT-' + String(next).padStart(3,'0');
}

document.getElementById('newPricingType').onchange = (e) => {
  const wrap = document.getElementById('priceFieldWrap');
  if(e.target.value === 'free'){
    wrap.style.display = 'none';
    document.getElementById('newPrice').value = '0';
  } else {
    wrap.style.display = 'block';
    document.getElementById('newPrice').value = '';
  }
};

let newImageData = null;
document.getElementById('newImage').onchange = (e) => {
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    newImageData = ev.target.result;
    const prev = document.getElementById('imgPreview');
    prev.src = newImageData;
    prev.style.display = 'block';
  };
  reader.readAsDataURL(file);
};

document.getElementById('addTemplateBtn').onclick = async () => {
  const title = document.getElementById('newTitle').value.trim();
  const category = document.getElementById('newCategory').value;
  const pricingType = document.getElementById('newPricingType').value;
  const price = pricingType === 'free' ? 0 : document.getElementById('newPrice').value;
  const rating = document.getElementById('newRating').value;
  const link = document.getElementById('newLink').value.trim();

  if(!title || price === '' || price === null || !link || !newImageData){
    alert('Please complete all fields and upload a preview image.');
    return;
  }

  const id = 'UT-' + String(templates.length + 1).padStart(3,'0');
  const template = {
    id, title, category, price:Number(price), rating:Number(rating),
    image:newImageData, link, sold:0, dateAdded:new Date().toLocaleString('en-PH')
  };
  templates.push(template);
  await saveTemplates();

  document.getElementById('newTitle').value = '';
  document.getElementById('newPrice').value = '';
  document.getElementById('newLink').value = '';
  document.getElementById('imgPreview').style.display = 'none';
  newImageData = null;
  updateAutoId();
  renderAll();
  alert('Template added to your shop!');
};

// ---------- MANAGE LIST ----------
function renderManageList(){
  const el = document.getElementById('manageList');
  if(templates.length === 0){
    el.innerHTML = `<div class="empty-admin">You haven't uploaded any templates yet.</div>`;
    return;
  }
  el.innerHTML = templates.map(t => `
    <div class="admin-item">
      <img src="${t.image}">
      <div class="admin-item-info">
        <h5>${t.id} — ${t.title}</h5>
        <span>${peso(t.price)} · ${t.sold||0} sold · ${t.rating}★</span>
      </div>
      <button class="del-btn" onclick="deleteTemplate('${t.id}')">Remove</button>
    </div>
  `).join('');
}
async function deleteTemplate(id){
  if(!confirm('Remove this template from your shop?')) return;
  templates = templates.filter(t=>t.id!==id);
  await saveTemplates();
  renderAll();
}

// ---------- ORDERS ----------
function renderOrdersList(){
  const el = document.getElementById('ordersList');
  if(orders.length === 0){
    el.innerHTML = `<div class="empty-admin">No orders yet.</div>`;
    return;
  }
  el.innerHTML = orders.map(o => `
    <div class="order-card">
      <div class="oc-top">
        <span class="oc-id">${o.orderId}</span>
        <span class="order-status ${o.status}">${o.status}</span>
      </div>
      <p><b>${o.templateName}</b> — ${peso(o.price)}</p>
      <p>Buyer: ${o.buyerName} (${o.buyerEmail})</p>
      <p>GCash Ref: ${o.gcashRef}</p>
      <p>${o.date}</p>
      ${o.status==='pending' ? `
        <div class="oc-actions">
          <button class="oc-btn approve" onclick="approveOrder('${o.orderId}')">Verify & Approve</button>
        </div>
      ` : `
        <div class="oc-actions">
          <button class="oc-btn link" onclick="copyDeliveryLink('${o.templateId}')">Copy Template Link to Send</button>
        </div>
      `}
    </div>
  `).join('');
}

async function approveOrder(orderId){
  const order = orders.find(o=>o.orderId===orderId);
  if(!order) return;
  order.status = 'approved';
  const t = templates.find(x=>x.id===order.templateId);
  if(t){ t.sold = (t.sold||0) + 1; }
  await saveOrders();
  await saveTemplates();
  renderAll();
  alert('Order approved! Remember to manually send the template link to ' + order.buyerEmail);
}

function copyDeliveryLink(templateId){
  const t = templates.find(x=>x.id===templateId);
  if(!t) return;
  navigator.clipboard.writeText(t.link).then(()=>{
    alert('Link copied! Paste it into an email or message to the buyer.');
  });
}

loadData();
</script>
</body>
</html>
